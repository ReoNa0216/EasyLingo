{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyLingo",
  "version": "1.0.0",
  "identifier": "com.reona0216.easylingo",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "python -m http.server 1420 --directory src"
  },
  "app": {

    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "EasyLingo",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
