{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyLingo",
  "version": "1.1.0",
  "identifier": "com.reona0216.easylingo",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "python -m http.server 1420 --directory src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "EasyLingo",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright (c) 2024 ReoNa0216",
    "category": "Education",
    "shortDescription": "AI-powered language learning app",
    "longDescription": "EasyLingo is a desktop language learning application with AI extraction and SRS review system.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese"]
      }
    }
  }
}
